{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.setup.ts",
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx"
  ]
}
